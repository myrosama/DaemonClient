rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user data — only the owning user may read or write.
    match /artifacts/{appId}/users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Operator broadcast announcements — any authenticated user may read.
    // Writes happen ONLY via service accounts (deployment-service / backend),
    // which bypass these rules — so client writes are flatly denied. The old
    // `allow write: if request.auth != null` let ANY signed-in user publish
    // an "announcement" shown to every user (phishing vector).
    match /global/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
