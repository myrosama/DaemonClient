# =========================================
# SENSITIVE & SECRET FILES
# =========================================
# Ignore environment variables files
.env
.env.*
!.env.example

# Ignore Google Cloud service account keys
serviceAccountsKey.json


# Ignore Telethon session files, which contain login credentials
*.session
*.session-journal


# =========================================
# PYTHON
# =========================================
# Ignore virtual environments
venv/
.venv/
env/
ENV/

# Ignore Python cache files and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore package distribution folders
build/
dist/
*.egg-info/


# =========================================
# NODE.JS / FIREBASE FUNCTIONS
# =========================================
# Ignore dependency folders
node_modules/

# Ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
firebase-debug.log*
.firebase/

# Ignore build output
lib/
lib-es6/


# =========================================
# OPERATING SYSTEM & EDITOR FILES
# =========================================
# macOS
.DS_Store

# Windows
Thumbs.db

# VSCode
.vscode/

# Ignore the environment file for Cloud Functions
functions/.env

daemonclient-desktop/node_modules
daemon-cli/src/daemonclient/config.py

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example

# pnpm and build artifacts
.pnpm-store/
immich/web/build/
accounts-portal/dist/
deployment-service/src/shim-bundle.ts
deployment-service/scripts/
backend-server/myenv/

# AI History, scratch, and temporary logs
memory/
scratch/
docs/photos/
docs/superpowers/
docs/v2.0.0-COMPLETION-REPORT.md
BUG_FIXES_*.md
CRITICAL_FIXES_DEPLOYED.md
DEPLOYMENT_FINAL_*.md
PRIORITY_QUEUE_DEPLOYED.md
PROJECT_ROADMAP.md
immich-api-shim/tail_logs*.json
